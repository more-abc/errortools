root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
max_line_length = 120  

[*.{c,h}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.txt]
trim_trailing_whitespace = false

[*.{yml,yaml,ini}]
indent_size = 2

[.gitignore]
indent_size = 4